<UserControl x:Class="Ordir.Views.InfoTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900"
             Background="Transparent">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,4,12,16">
    <RichTextBox x:Name="AboutRich" MaxWidth="820" HorizontalAlignment="Left"
                 IsDocumentEnabled="True"
                 IsReadOnly="True" IsUndoEnabled="False" IsTabStop="False"
                 BorderThickness="0" Background="Transparent" Padding="0"
                 Foreground="{StaticResource Brush.Text}"
                 CaretBrush="{StaticResource Brush.Muted}"
                 VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled"/>
  </ScrollViewer>
</UserControl>
