<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Repo-level source so restore works even if machine/user NuGet.config has no feeds (fixes NU1100 for runtime packs). -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
